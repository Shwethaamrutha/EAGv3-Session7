{
  "manifest_version": 3,
  "name": "RAG Research Assistant",
  "version": "1.0.0",
  "description": "Index any webpage into your FAISS knowledge base and chat across all indexed pages",
  "permissions": ["activeTab", "sidePanel", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": "icons/icon48.png",
    "default_title": "RAG Assistant"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
